{
  "name": "@whenmoon-afk/memory-mcp",
  "version": "4.2.0",
  "description": "Identity persistence for AI agents - MCP server",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "memory-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prerelease": "npm run typecheck && npm test && npm run build",
    "release": "npm run prerelease && git tag v$(node -p \"require('./package.json').version\") && git push origin v$(node -p \"require('./package.json').version\")",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "identity",
    "persistence",
    "ai",
    "memory"
  ],
  "author": "WhenMoon-afk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whenmoon-afk/claude-memory-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/whenmoon-afk/claude-memory-mcp/issues"
  },
  "homepage": "https://github.com/whenmoon-afk/claude-memory-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
